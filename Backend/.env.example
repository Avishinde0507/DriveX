PORT=8080
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_key_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─────────────────────────────────────────────────────
# EMAIL CONFIGURATION
# ─────────────────────────────────────────────────────

# Resend API — RECOMMENDED for production (Render/Railway/Docker)
# Ports 465/587 are blocked by cloud providers; Resend uses HTTPS instead.
# Free plan: 100 emails/day, 3000/month — https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM=DriveX <noreply@yourdomain.com>

# Gmail SMTP — fallback for local development only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
SMTP_FROM="DriveX Support" <your_email@gmail.com>
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password

# Client Application URL
CLIENT_URL=http://localhost:5173

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
